{
  "run_name": "qwen_0_5b_gguf_smoke",
  "model_ref": "qwen_0_5b_gguf_cpu",
  "model": {
    "backend": {
      "port": 18002,
      "ctx_size": 4096,
      "device": "auto"
    },
    "generation": {
      "max_tokens": 512,
      "temperature": 0.1,
      "top_p": 1.0,
