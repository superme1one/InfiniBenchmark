    "drop": {
      "enabled": true,
      "path": "data_sets/DROP/validation.jsonl",
      "limit": 1,
      "cooldown_ms": 100,
      "timeout_ms": 120000
    },
    "mmlu": {
      "enabled": true,
      "path": "data_sets/MMLU",
      "limit_per_subject": 1,
      "cooldown_ms": 50,
      "timeout_ms": 120000
    },
    "triviaqa": {
      "enabled": true,
      "path": "data_sets/TriviaQA/verified-web-dev.json",
      "limit": 1,
      "cooldown_ms": 100,
      "timeout_ms": 120000
    }
  }
}
