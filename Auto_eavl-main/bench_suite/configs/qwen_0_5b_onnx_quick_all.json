{
  "run_name": "qwen_0_5b_onnx_quick_all",
  "model_ref": "qwen_0_5b_onnx",
  "model": {
    "backend": {
      "port": 18013,
      "device": "cpu"
    },
    "generation": {
      "max_tokens": 256,
      "temperature": 0.1,
      "top_p": 1.0,
      "top_k": 1
    }
  },
  "datasets": {
    "gsm8k": {
      "enabled": true,
      "path": "data_sets/GSM8k/test.jsonl",
      "limit": 10,
      "cooldown_ms": 100,
      "timeout_ms": 120000
    },
    "drop": {
      "enabled": true,
      "path": "data_sets/DROP/validation.jsonl",
      "limit": 10,
      "cooldown_ms": 100,
      "timeout_ms": 120000
    },
    "mmlu": {
      "enabled": true,
      "path": "data_sets/MMLU",
      "limit_per_subject": 1,
      "max_samples": 10,
      "cooldown_ms": 50,
      "timeout_ms": 120000
    },
    "triviaqa": {
      "enabled": true,
      "path": "data_sets/TriviaQA/verified-web-dev.json",
      "limit": 10,
      "cooldown_ms": 100,
      "timeout_ms": 120000
    }
  }
}
